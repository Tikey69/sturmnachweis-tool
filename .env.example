# ─────────────────────────────────────────────
# Sturmnachweis-Tool — Umgebungsvariablen
# Kopieren nach .env und ausfüllen
# ─────────────────────────────────────────────

# Optional: Visual Crossing API Key (kostenlos unter visualcrossing.com)
# Wird nur als Fallback-Quelle benötigt. Ohne Key läuft das Tool trotzdem.
VISUAL_CROSSING_API_KEY=

# Optional: KNMI API Key (kostenlos registrieren unter dataplatform.knmi.nl)
# Wird für niederländische Grenzstationen (Isselburg/Bocholt-West) benötigt.
KNMI_API_KEY=

# Port, auf dem nginx erreichbar sein soll (Standard: 80)
EXPOSE_PORT=80

# Log-Level für das Backend: debug | info | warning | error
LOG_LEVEL=info

# Firmenname für PDF-Kopfzeile
COMPANY_NAME=Versicherungsmakler

# Optionaler Zusatz für PDF-Footer (z.B. Kanzleiname)
COMPANY_FOOTER=Erstellt mit Sturmnachweis-Tool

# Optional: BBV-Net Zugangsdaten (Bocholter-Borkener Volksblatt)
# Nur erforderlich wenn BBV-Net hinter einem Login liegt.
# Kostenlose Registrierung unter: www.bbv-net.de
BBV_USERNAME=
BBV_PASSWORD=
